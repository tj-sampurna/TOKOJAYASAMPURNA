# ─────────────────────────────────────────────────────────────────
# .env.example  —  salin ke .env lalu isi nilainya
# ─────────────────────────────────────────────────────────────────

# ── Supabase (Frontend / Vite) ────────────────────────────────────
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase (Backend / Server Express) ──────────────────────────
# Gunakan Service Role Key di server.ts — JANGAN expose ke frontend
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Midtrans Credentials ──────────────────────────────────────────
# Gunakan Server Key & Client Key dari Dashboard Midtrans Anda (Sandbox/Production Mode)
MIDTRANS_SERVER_KEY=your-midtrans-server-key
VITE_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
VITE_MIDTRANS_IS_PRODUCTION=false

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
